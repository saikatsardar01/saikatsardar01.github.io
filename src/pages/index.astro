<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Saikat K S | Student,Software Engineer & Researcher</title>
		<meta
			name="description"
			content="Portfolio of Saikat Kumar Sardar, B.Tech CSE at MSIT Kolkata. Specialized in Python, low-latency architecture, and optimization."
		/>
		<script src="https://cdn.tailwindcss.com"></script>
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap"
			rel="stylesheet"
		/>
		<style>
			:root {
				--bg: #0b1220;
				--muted: #94a3b8;
				--accent-from: #38bdf8;
				--accent-to: #818cf8;
			}
			body {
				font-family: "Inter", sans-serif;
				background: var(--bg);
				color: #f8fafc;
				margin: 0;
				width: 100%;
				height: 100%;
			}
			.glass-card {
				background: linear-gradient(
					135deg,
					rgba(255, 255, 255, 0.02),
					rgba(255, 255, 255, 0.01)
				);
				backdrop-filter: blur(8px);
				border: 1px solid rgba(255, 255, 255, 0.06);
				box-shadow: 0 10px 30px rgba(2, 6, 23, 0.6);
			}
			.gradient-text {
				background: linear-gradient(
					to right,
					var(--accent-from),
					var(--accent-to)
				);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.nav-link {
				color: var(--muted);
				transition:
					color 0.18s ease,
					transform 0.18s ease;
			}
			.nav-link:hover {
				color: #fff;
				transform: translateY(-1px);
			}
			.hero-cta {
				box-shadow: 0 8px 30px rgba(99, 102, 241, 0.12);
			}
			.rounded-portrait {
				border-radius: 14px;
				border: 1px solid rgba(255, 255, 255, 0.04);
			}
			@media (max-width: 768px) {
				header {
					padding-top: 6rem;
					padding-bottom: 3rem;
				}
			}
		</style>
	</head>
	<script>
		async function loadCodeforces() {
			try {
				const response = await fetch(
					"https://codeforces.com/api/user.info?handles=saikatsardar180",
				);

				const data = await response.json();

				if (!data.result?.length) return;

				const user = data.result[0];

				const handle = document.getElementById("cf-handle");
				if (!handle) return;

				handle.textContent = `${user.handle}`;

				const rank = user.rank || "";

				const colors: Record<string, string> = {
					newbie: "#808080",
					pupil: "#008000",
					specialist: "#03A89E",
					expert: "#0000FF",
					candidate_master: "#AA00AA",
					master: "#FF8C00",
					international_master: "#FF8C00",
					grandmaster: "#FF0000",
					international_grandmaster: "#FF0000",
					legendary_grandmaster: "#FF0000",
				};

				handle.style.color = colors[rank] || "#94a3b8";
			} catch (err) {
				console.error(err);
			}
		}

		loadCodeforces();
	</script>
